{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug Build",
      "description": "Debug build with tests and ASAN",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "BUILD_APPS": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "Release Build",
      "description": "Optimized release build",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "OFF",
        "BUILD_APPS": "OFF"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage Build",
      "description": "Debug build with code coverage enabled",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON",
        "BUILD_APPS": "OFF",
        "ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "apps",
      "displayName": "Apps Build",
      "description": "Build with applications",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "OFF",
        "BUILD_APPS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Build Debug"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "displayName": "Build Release"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "displayName": "Build Coverage"
    },
    {
      "name": "apps",
      "configurePreset": "apps",
      "displayName": "Build Apps"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "displayName": "Test Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "displayName": "Test Coverage",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
